<?xml version="1.0" encoding="UTF-8"?>

<?import com.demo3.view.TreeCanvasView?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.Slider?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.demo3.controller.TreeVisualizerController">
    <children>
        <VBox fx:id="mainMenuView" alignment="CENTER" spacing="18.0" styleClass="main-menu">
            <padding>
                <Insets top="40.0" right="40.0" bottom="40.0" left="40.0"/>
            </padding>
            <children>
                <Label text="Tree Operation Visualizer" styleClass="main-title"/>
                <Label text="Visualize Generic Tree, Binary Search Tree, and Red-Black Tree operations&#10;with step-by-step pseudocode, playback, and state history."
                       styleClass="main-subtitle"/>
                <Label text="Structured packages now separate controller, service, util, and view responsibilities."
                       styleClass="main-note"/>
                <Button fx:id="openGenericButton" text="Open Generic Tree" prefWidth="340.0" prefHeight="50.0" styleClass="menu-action"/>
                <Button fx:id="openBinaryButton" text="Open Binary Search Tree" prefWidth="340.0" prefHeight="50.0" styleClass="menu-action"/>
                <Button fx:id="openRedBlackButton" text="Open Red-Black Tree" prefWidth="340.0" prefHeight="50.0" styleClass="menu-action"/>
                <HBox alignment="CENTER" spacing="10.0">
                    <children>
                        <Button fx:id="helpMenuButton" text="Help" prefWidth="160.0"/>
                        <Button fx:id="quitButton" text="Quit" prefWidth="160.0"/>
                    </children>
                </HBox>
            </children>
        </VBox>

        <BorderPane fx:id="visualizerView" styleClass="visualizer-root">
            <padding>
                <Insets top="14.0" right="14.0" bottom="14.0" left="14.0"/>
            </padding>
            <top>
                <HBox alignment="CENTER_LEFT" spacing="12.0" BorderPane.alignment="CENTER">
                    <padding>
                        <Insets bottom="12.0"/>
                    </padding>
                    <children>
                        <Button fx:id="backToMenuButton" text="Back to Menu"/>
                        <Label text="Visualizer" styleClass="panel-title"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label text="Tree Type:"/>
                        <ComboBox fx:id="treeSelector" prefWidth="170.0"/>
                        <Button fx:id="helpVisualizerButton" text="Help"/>
                    </children>
                </HBox>
            </top>
            <left>
                <VBox spacing="10.0" styleClass="card" prefWidth="270.0" BorderPane.alignment="TOP_LEFT">
                    <padding>
                        <Insets top="16.0" right="16.0" bottom="16.0" left="16.0"/>
                    </padding>
                    <children>
                        <Label text="Operations" styleClass="section-title"/>
                        <Button fx:id="createButton" text="Create Empty Tree" maxWidth="1.7976931348623157E308"/>
                        <Label text="Parent value is used only for Generic Tree."/>
                        <TextField fx:id="parentField" promptText="Parent value"/>
                        <TextField fx:id="valueField" promptText="Value"/>
                        <TextField fx:id="newValueField" promptText="New value"/>
                        <Label text="Traversal"/>
                        <ComboBox fx:id="traversalSelector"/>
                        <Label text="Validation / guidance"/>
                        <Label fx:id="validationLabel" wrapText="true"/>
                        <Button fx:id="insertButton" text="Insert" maxWidth="1.7976931348623157E308"/>
                        <Button fx:id="deleteButton" text="Delete" maxWidth="1.7976931348623157E308"/>
                        <Button fx:id="updateButton" text="Update" maxWidth="1.7976931348623157E308"/>
                        <Button fx:id="searchButton" text="Search" maxWidth="1.7976931348623157E308"/>
                        <Button fx:id="traverseButton" text="Traverse" maxWidth="1.7976931348623157E308"/>
                        <Separator/>
                        <Button fx:id="undoButton" text="Undo" maxWidth="1.7976931348623157E308"/>
                        <Button fx:id="redoButton" text="Redo" maxWidth="1.7976931348623157E308"/>
                    </children>
                </VBox>
            </left>
            <center>
                <BorderPane styleClass="card" BorderPane.alignment="CENTER">
                    <padding>
                        <Insets top="12.0" right="12.0" bottom="12.0" left="12.0"/>
                    </padding>
                    <center>
                        <TreeCanvasView fx:id="treeCanvas"/>
                    </center>
                </BorderPane>
            </center>
            <right>
                <VBox spacing="12.0" styleClass="card" prefWidth="360.0" BorderPane.alignment="TOP_RIGHT">
                    <padding>
                        <Insets top="16.0" right="16.0" bottom="16.0" left="16.0"/>
                    </padding>
                    <children>
                        <Label text="Code / Pseudocode" styleClass="section-title"/>
                        <Label text="The highlighted line shows the current step in the operation trace." wrapText="true" styleClass="note-label"/>
                        <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS">
                            <content>
                                <VBox fx:id="codePanel" spacing="8.0">
                                    <padding>
                                        <Insets top="10.0" right="10.0" bottom="10.0" left="10.0"/>
                                    </padding>
                                </VBox>
                            </content>
                        </ScrollPane>
                    </children>
                </VBox>
            </right>
            <bottom>
                <HBox alignment="CENTER_LEFT" spacing="12.0" BorderPane.alignment="CENTER">
                    <padding>
                        <Insets top="12.0"/>
                    </padding>
                    <children>
                        <VBox spacing="6.0">
                            <children>
                                <Label fx:id="statusLabel" text="Choose a tree type to begin."/>
                                <Label fx:id="stepLabel" text="No operation selected."/>
                                <Label fx:id="traceCounterLabel" text="Step 0 / 0"/>
                                <Label fx:id="legendLabel" text="Legend: orange border = highlighted node, red/black fill = Red-Black color." wrapText="true"/>
                            </children>
                        </VBox>
                        <Region HBox.hgrow="ALWAYS"/>
                        <VBox spacing="4.0" prefWidth="180.0">
                            <children>
                                <Label text="Animation speed"/>
                                <Slider fx:id="speedSlider" min="0.4" max="2.2" value="1.0"/>
                            </children>
                        </VBox>
                        <Button fx:id="stepBackButton" text="Step Back"/>
                        <Button fx:id="playPauseButton" text="Play"/>
                        <Button fx:id="stepForwardButton" text="Step Forward"/>
                        <ProgressBar fx:id="progressBar" prefWidth="260.0" progress="0.0"/>
                    </children>
                </HBox>
            </bottom>
        </BorderPane>
    </children>
</StackPane>
